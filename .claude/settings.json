{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(//tmp/**)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "awaySummaryEnabled": false,
  "theme": "auto",
  "tui": "fullscreen"
}
